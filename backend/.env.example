# Copy to .env and adjust. Compose reads this automatically.

# ---- Database credentials / name (used by both profiles) --------------------
POSTGRES_USER=appointment
POSTGRES_PASSWORD=change_me
POSTGRES_DB=appointment_booking

# ---- LOCAL container (profile: localdb) -------------------------------------
# Host port for the local dev DB. Kept off 5432 to avoid clashing.
DB_PORT=5433

# ---- BOOTSTRAP target (profile: bootstrap) ----------------------------------
# Where the bootstrap job connects. For the LOCAL container use 5433; for the
# EXISTING VPS Postgres use its published port (commonly 5432) and that
# instance's superuser credentials above.
PGHOST=127.0.0.1
PGPORT=5432

# ---- App connection string (for your Node service) --------------------------
# Local:  postgresql://appointment:change_me@localhost:5433/appointment_booking
# VPS:    postgresql://<user>:<pass>@localhost:5432/appointment_booking
DATABASE_URL=postgresql://appointment:change_me@localhost:5433/appointment_booking