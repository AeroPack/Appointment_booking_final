{
  "findSlotsSchema": {
    "type": "object",
    "properties": {
      "doctor_id": {
        "type": "string",
        "format": "uuid"
      },
      "from": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "to": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    },
    "required": [
      "doctor_id",
      "from"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  },
  "bookSlotSchema": {
    "type": "object",
    "properties": {
      "doctor_id": {
        "type": "string",
        "format": "uuid"
      },
      "scheduled_start": {
        "type": "string",
        "format": "date-time"
      },
      "patient_id": {
        "type": "string",
        "format": "uuid"
      },
      "idempotency_key": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      }
    },
    "required": [
      "doctor_id",
      "scheduled_start",
      "idempotency_key"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}